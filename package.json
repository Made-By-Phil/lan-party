{
  "name": "lan-party",
  "version": "0.1.0",
  "description": "An opinionated backbone for hosting quick local-multiplayer browser games on your LAN.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lan-party": "dist/cli.js"
  },
  "files": [
    "dist/",
    "shell/",
    "games/",
    "src/"
  ],
  "exports": {
    "./sdk": "./src/sdk.ts"
  },
  "scripts": {
    "dev": "node src/cli.ts",
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
